FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    AUTO_SEED_ON_START=1 \
    AUTO_SEED_ONLY_IF_EMPTY=1 \
    SEED_READERS=200 \
    SEED_WRITERS=30 \
    SEED_READER_PASSWORD=Reader@123 \
    SEED_WRITER_PASSWORD=Writer@123 \
    SEED_STORIES_PER_WRITER=2 \
    SEED_POEMS_PER_WRITER=1 \
    SEED_BOOKS_PER_WRITER=1 \
    SEED_CHAPTERS_PER_BOOK=2 \
    SEED_FOLLOWS_PER_READER=2 \
    SEED_LIKES_PER_READER=3 \
    SEED_COMMENTS_PER_READER=1 \
    SEED_PROGRESS_PER_READER=2 \
    SEED_AVATAR_POOL_SIZE=24 \
    SEED_COVER_POOL_SIZE=36 \
    SEED_MIN_BODY_PARAGRAPHS=4 \
    SEED_MAX_BODY_PARAGRAPHS=7 \
    SEED_MIN_BODY_WORDS=22 \
    SEED_MAX_BODY_WORDS=40 \
    SEED_SKIP_BODY_REFRESH=1 \
    SEED_SKIP_SMOKE_CHECK=1

WORKDIR /app

COPY requirements.txt /app/
RUN pip install --upgrade pip && pip install -r requirements.txt

COPY . /app
