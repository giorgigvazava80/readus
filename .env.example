SECRET_KEY=change-this-to-a-long-random-secret-key-32-plus-chars
DEBUG=1

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOW_ALL_ORIGINS=0

DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432
# Optional for hosted environments (overrides DB_* when set)
# DATABASE_URL=postgres://user:password@host:5432/dbname

API_PORT=9000
FRONTEND_PORT=5173
ADMIN_FRONTEND_PORT=5174
DB_EXPOSE_PORT=5432
VITE_API_BASE_URL=http://localhost:9000
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/login
VITE_EMAIL_VERIFICATION_REQUIRED=0
FRONTEND_BASE_URL=http://localhost:5173
ACCOUNT_EMAIL_VERIFICATION=none
SOCIAL_AUTH_GOOGLE_CALLBACK_URL=http://localhost:5173/login
SOCIAL_AUTH_FACEBOOK_CALLBACK_URL=http://localhost:5173/login
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret
GOOGLE_EMAIL_AUTHENTICATION=1
GOOGLE_EMAIL_AUTHENTICATION_AUTO_CONNECT=1
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
VITE_MAIN_APP_HOSTS=localhost,127.0.0.1
VITE_ADMIN_APP_HOSTS=admin.localhost

THROTTLE_ANON=60/min
THROTTLE_USER=180/min
API_PAGE_SIZE=20

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_HOST=smtp.mail.yahoo.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_yahoo_email@yahoo.com
EMAIL_HOST_PASSWORD=your_yahoo_app_password
DEFAULT_FROM_EMAIL=your_yahoo_email@yahoo.com
EMAIL_TIMEOUT=30
EMAIL_SEND_ASYNC=1
CONTENT_UPLOAD_ASYNC=1
CONTENT_UPLOAD_WORKERS=2

BOOTSTRAP_ROOT=1
ROOT_EMAIL=root@test.ge
ROOT_USERNAME=root
ROOT_PASSWORD=ChangeMe@123
BOOTSTRAP_FORCE_PASSWORD_CHANGE=1
BOOTSTRAP_ROOT_RESET_PASSWORD=0

GUNICORN_WORKERS=3

RUN_COLLECTSTATIC=1
SERVE_MEDIA=1
STATIC_BROWSER_CACHE_SECONDS=86400
MEDIA_BROWSER_CACHE_SECONDS=3600
# Optional: override where uploaded media is stored.
# In production (Render persistent disk), set MEDIA_ROOT=/var/data/media
# MEDIA_ROOT=media
# MEDIA_URL=/media/

# Optional cache (Redis/Key Value). Keep empty to use in-process local cache.
# For Docker compose: CACHE_URL=redis://redis:6379/1
CACHE_URL=
CACHE_KEY_PREFIX=readus
CACHE_DEFAULT_TIMEOUT=300
CACHE_TTL_PUBLIC_LIST=120
CACHE_TTL_PUBLIC_DETAIL=300
CACHE_REDIS_SOCKET_TIMEOUT=2
CACHE_REDIS_SOCKET_CONNECT_TIMEOUT=2
CACHE_REDIS_HEALTH_CHECK_INTERVAL=30
CACHE_REDIS_MAX_CONNECTIONS=100
CACHE_REDIS_RETRY_ON_TIMEOUT=1

