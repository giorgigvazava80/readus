SECRET_KEY=change-this-to-a-long-random-secret-key-32-plus-chars
DEBUG=1

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOW_ALL_ORIGINS=0

DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432
# Optional for hosted environments (overrides DB_* when set)
# DATABASE_URL=postgres://user:password@host:5432/dbname

API_PORT=9000
FRONTEND_PORT=5173
ADMIN_FRONTEND_PORT=5174
DB_EXPOSE_PORT=5432
VITE_API_BASE_URL=http://localhost:9000
FRONTEND_BASE_URL=http://localhost:5173
VITE_MAIN_APP_HOSTS=localhost,127.0.0.1
VITE_ADMIN_APP_HOSTS=admin.localhost

THROTTLE_ANON=60/min
THROTTLE_USER=180/min
API_PAGE_SIZE=20

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_HOST=smtp.mail.yahoo.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_yahoo_email@yahoo.com
EMAIL_HOST_PASSWORD=your_yahoo_app_password
DEFAULT_FROM_EMAIL=your_yahoo_email@yahoo.com
EMAIL_TIMEOUT=30
EMAIL_SEND_ASYNC=1

BOOTSTRAP_ROOT=1
ROOT_EMAIL=root@test.ge
ROOT_USERNAME=root
ROOT_PASSWORD=ChangeMe@123
BOOTSTRAP_FORCE_PASSWORD_CHANGE=1
BOOTSTRAP_ROOT_RESET_PASSWORD=0

RUN_COLLECTSTATIC=1

